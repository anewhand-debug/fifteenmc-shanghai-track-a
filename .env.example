# Optional API keys. Never commit a populated .env file.
AMAP_API_KEY=
MAPBOX_TOKEN=
AQICN_TOKEN=

# Local raw data root. The notebooks default to the parent project data folder.
FIFTEENMC_RAW_DATA_ROOT=D:/fifteenmcproject

# Optional development limits for quick smoke runs.
# Leave blank for full analysis.
FIFTEENMC_GRID_LIMIT=
FIFTEENMC_POI_LIMIT=
